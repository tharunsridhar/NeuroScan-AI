# NeuroScan AI environment template
# Copy this file to `.env` for local development.
# Never commit your real `.env` file.

# Optional. Enables Groq-based AI report generation.
# If empty, the API uses a local fallback report.
GROQ_API_KEY=

# Optional. Comma-separated allowed browser origins.
# Use * for local testing. Use your frontend domain in production.
NEUROSCAN_CORS_ORIGINS=*

# Optional. Maximum MRI upload size in MB.
NEUROSCAN_MAX_UPLOAD_MB=25

# Optional. Custom model folder path.
# Leave blank to use the repository-local MODEL/ folder.
NEUROSCAN_MODELS_DIR=

# Optional. Runtime host and port used by deploy/start.sh.
NEUROSCAN_HOST=0.0.0.0
NEUROSCAN_PORT=8000
